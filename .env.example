# Django
DEBUG=True
SECRET_KEY=change-me

# Local development stays on SQLite by default.
USE_POSTGRES=False

# Turn this on only after your PostgreSQL server, user, and database exist.
# USE_POSTGRES=True
# DATABASE_URL=postgresql://postgres:your-password@localhost:5432/libra_db
# POSTGRES_DB=libra_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your-password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# DB_CONN_MAX_AGE=60

# For Plesk / hoster.kz with MySQL or MariaDB use this instead.
# USE_MYSQL=True
# MYSQL_DATABASE=libra_db
# MYSQL_USER=libra_user
# MYSQL_PASSWORD=your-password
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# DATABASE_URL=mysql://libra_user:your-password@localhost:3306/libra_db
# ALLOWED_HOSTS=127.0.0.1,localhost,your-domain.kz,www.your-domain.kz

# Backblaze B2 (S3 API) for media files on production
# USE_S3=True
# B2_ACCESS_KEY_ID=your-key-id
# B2_SECRET_ACCESS_KEY=your-application-key
# B2_BUCKET_NAME=your-bucket-name
# B2_REGION=us-east-005
# B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
# B2_MEDIA_PUBLIC_DOMAIN=your-custom-domain-or-empty
# B2_MEDIA_PUBLIC=true
